# Neighborhood BBS - Environment Variables
# Copy this file to .env and update with your values
# ⚠️  SECURITY: Never commit .env with real secrets - it's in .gitignore for a reason!

# Flask Configuration
FLASK_APP=src/server.py
FLASK_ENV=development
DEBUG=false

# Server Configuration
# ⚠️  SECURITY: Generate secure SECRET_KEY with: python -c "import os; print(os.urandom(32).hex())"
HOST=0.0.0.0
PORT=8080
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Database Configuration
DATABASE_URL=sqlite:///data/neighborhood.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/neighborhood_bbs

# Network Configuration
MAX_CONNECTIONS=100
MESSAGE_TIMEOUT=300

# Logging
LOG_LEVEL=INFO

# Admin Session
ADMIN_SESSION_TIMEOUT=3600  # 1 hour default - increase for production/decrease for security

# CORS Configuration (for Docker deployments)
CORS_ORIGINS=http://localhost:8080

# Session Security (enable in production with HTTPS)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Optional: API Keys and External Services
# OPEN_AI_KEY=your-key-here
# MAPBOX_KEY=your-key-here

# ⚠️  PRODUCTION SECURITY CHECKLIST:
# [ ] Set unique, random SECRET_KEY (64+ characters)
# [ ] Set DEBUG=false
# [ ] Set HOST=127.0.0.1 (use reverse proxy for external)
# [ ] Enable SESSION_COOKIE_SECURE=true (requires HTTPS)
# [ ] Rotate SECRET_KEY every 90 days
# [ ] Use strong admin credentials (min 16 chars, mixed case, numbers, symbols)
# [ ] Set up automated backups for DATABASE_URL
# [ ] Enable LOG_LEVEL=INFO or WARNING (not DEBUG)

