@baseUrl = http://localhost:8080
@contentType = application/json

###############################################################################
# NEIGHBORHOOD BBS - API TEST FILE
# 
# Instructions:
# 1. Install VS Code extension: REST Client (humao.rest-client)
# 2. Start the server: python src/main.py
# 3. Click "Send Request" above each test block to execute
# 4. Results appear in the "Response" panel
#
# Test Coverage:
# - Health checks
# - Chat rooms (CRUD)
# - Chat messages
# - Board posts (CRUD)
# - Post replies
# - Error handling
# - Rate limiting
# - Input validation
###############################################################################

###############################################################################
# HEALTH & STATUS TESTS
###############################################################################

### Health Check
# Expected: 200 OK with {"status": "ok", "app": "Neighborhood BBS"}
GET @baseUrl/health

### Home Page
# Expected: 200 OK with HTML content
GET @baseUrl/

### 404 Error Test
# Expected: 404 Not found
GET @baseUrl/nonexistent

###############################################################################
# CHAT ROOMS - GET OPERATIONS
###############################################################################

### Get All Chat Rooms
# Expected: 200 OK with array of rooms
GET @baseUrl/api/chat/rooms

### Get Chat Rooms (with pagination - future feature)
GET @baseUrl/api/chat/rooms?limit=5&offset=0

###############################################################################
# CHAT ROOMS - CREATE OPERATIONS
###############################################################################

### Create New Chat Room - Basic
# Expected: 201 Created with room_id
POST @baseUrl/api/chat/rooms
Content-Type: @contentType

{
  "name": "neighborhood-general",
  "description": "General discussion for the neighborhood"
}

### Create Chat Room - Minimal (no description)
# Expected: 201 Created
POST @baseUrl/api/chat/rooms
Content-Type: @contentType

{
  "name": "lost-and-found"
}

### Create Chat Room - Missing Name (should fail)
# Expected: 400 Bad Request with error message
POST @baseUrl/api/chat/rooms
Content-Type: @contentType

{
  "description": "No name provided"
}

### Create Chat Room - Empty Name (should fail)
# Expected: 400 Bad Request
POST @baseUrl/api/chat/rooms
Content-Type: @contentType

{
  "name": "",
  "description": "Empty name"
}

### Create Chat Room - With HTML Tags (XSS test)
# Expected: 201 Created with HTML stripped
POST @baseUrl/api/chat/rooms
Content-Type: @contentType

{
  "name": "<script>alert('xss')</script>test-room",
  "description": "<img src=x onerror=alert(1)>"
}

### Create Chat Room - Duplicate Name (should fail)
# Expected: 409 Conflict - Room already exists
POST @baseUrl/api/chat/rooms
Content-Type: @contentType

{
  "name": "neighborhood-general",
  "description": "Duplicate"
}

###############################################################################
# CHAT MESSAGES - SEND
###############################################################################

### Send Message - Basic
# Note: Replace room_id with actual ID from Get All Chat Rooms response
# Expected: 201 OK with message_id
POST @baseUrl/api/chat/send
Content-Type: @contentType

{
  "room_id": 26,
  "author": "Alice",
  "content": "Hey neighbors! Anyone want to organize a cleanup?"
}

### Send Message - Without Author (uses Anonymous)
# Expected: 201 OK
POST @baseUrl/api/chat/send
Content-Type: @contentType

{
  "room_id": 26,
  "content": "Quick question about parking"
}

